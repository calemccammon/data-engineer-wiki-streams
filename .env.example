# Kafka bootstrap (Redpanda)
KAFKA_BOOTSTRAP_SERVERS=localhost:19092

# Wikimedia SSE stream URL
WIKIMEDIA_SSE_URL=https://stream.wikimedia.org/v2/stream/recentchange

# Kafka topic
KAFKA_TOPIC_RAW_EDITS=wiki.raw-edits

# Ktor API port (note: docker-compose console uses 8080 — use 8090 for the API)
API_PORT=8090

# Kafka Streams application ID (consumer group)
KAFKA_STREAMS_APP_ID=wiki-streams-processor

# State store directory (Kafka Streams local state)
STATE_DIR=/tmp/kafka-streams/wiki-streams
